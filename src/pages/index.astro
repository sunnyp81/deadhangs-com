---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import GripChart from '../components/GripChart';
import HangTimer from '../components/HangTimer';
import ProtocolCalculator from '../components/ProtocolCalculator';
import SignupForm from '../components/SignupForm';
import '../styles/global.css';
---

<Base title="deadhangs.com — Hang longer. Live longer.">
  <Nav />

  <!-- HERO — typographic manifesto -->
  <section id="hero" style="position:relative;min-height:820px;padding:140px 64px 80px;background:var(--color-bg);overflow:hidden;">
    <!-- Backdrop ticker -->
    <div style="position:absolute;top:96px;left:0;right:0;font-family:var(--font-mono);font-size:11px;letter-spacing:.22em;color:var(--color-text-faint);text-align:center;text-transform:uppercase;white-space:nowrap;">
      <span style="margin-right:24px;">· DEADHANGS.COM ·</span>
      <span style="margin-right:24px;">EST. 2024 · BERKELEY, CA ·</span>
      <span style="margin-right:24px;">STUDY N=2,847 ·</span>
      <span style="margin-right:24px;">GRIP IS LIFE ·</span>
      <span>· DEADHANGS.COM ·</span>
    </div>

    <div id="hero-content" style="max-width:1100px;margin:0 auto;transform-origin:center 30%;">
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:32px;">
        <span class="dh-eyebrow">Vol. 1 · Issue 04 · Grip Strength</span>
        <span class="dh-eyebrow">·· 90 sec read</span>
      </div>

      <h1 class="dh-heavy" style="font-size:clamp(96px,14vw,220px);margin:0;color:var(--color-text);text-align:left;">
        HANG.<br/>
        <span style="color:var(--color-primary);">LONGER.</span><br/>
        LIVE.<br/>
        <span style="color:var(--color-text-muted);">LONGER.</span>
      </h1>

      <div style="display:grid;grid-template-columns:1.2fr 1fr;gap:48px;margin-top:56px;align-items:end;">
        <p class="dh-display" style="font-size:28px;font-weight:500;line-height:1.3;margin:0;color:var(--color-text);text-wrap:balance;">
          The single best predictor of all-cause mortality after 50 isn't your VO₂ max.
          It isn't your bench. It's how long you can hang from a bar.
          <span class="dh-cite" title="Bohannon RW. J Am Geriatr Soc. 2019">1</span>
        </p>
        <div style="display:flex;gap:12px;justify-content:flex-end;">
          <a href="#timer" class="dh-btn">Start the protocol</a>
          <a href="#science" class="dh-btn dh-btn-ghost">Read the science ↓</a>
        </div>
      </div>
    </div>

    <!-- scroll cue -->
    <div style="position:absolute;bottom:32px;left:50%;transform:translateX(-50%);font-family:var(--font-mono);font-size:10px;letter-spacing:.22em;color:var(--color-text-faint);text-transform:uppercase;">
      ↓ scroll · the data
    </div>
  </section>

  <!-- DATA STRIP -->
  <section id="science" style="background:var(--color-surface);border-top:1px solid var(--color-divider);border-bottom:1px solid var(--color-divider);padding:80px 64px;">
    <div style="max-width:1200px;margin:0 auto;">
      <div class="scroll-reveal">
        <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:32px;">
          <div>
            <div class="dh-eyebrow" style="margin-bottom:8px;">· FIG. 01 / GRIP × MORTALITY</div>
            <h2 class="dh-display" style="font-size:40px;font-weight:500;margin:0;max-width:720px;">
              Each <span style="color:var(--color-primary);">5 kg</span> increment in grip strength
              corresponds to a <span style="color:var(--color-primary);">16% reduction</span> in all-cause mortality risk.
            </h2>
          </div>
          <div style="text-align:right;min-width:180px;">
            <div class="dh-mono" style="font-size:12px;color:var(--color-text-muted);letter-spacing:.12em;">SOURCE</div>
            <div style="font-family:var(--font-mono);font-size:13px;color:var(--color-text);">Lancet, 2015</div>
            <div class="dh-mono" style="font-size:11px;color:var(--color-text-faint);margin-top:2px;">n = 139,691 · 17 nations</div>
          </div>
        </div>
      </div>

      <div class="scroll-reveal scroll-reveal-d3">
        <div style="background:var(--color-bg);padding:32px;border-radius:var(--radius-md);border:1px solid var(--color-divider);">
          <GripChart client:visible width={1100} height={300} />
        </div>
      </div>

      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--color-divider);margin-top:1px;border:1px solid var(--color-divider);">
        <div class="stat-cell">
          <div class="dh-heavy" style="font-size:56px;color:var(--color-primary);line-height:1;">−16%</div>
          <div style="font-family:var(--font-display);font-weight:600;font-size:14px;margin-top:12px;color:var(--color-text);">Mortality, per 5kg grip</div>
          <div class="dh-mono" style="font-size:11px;color:var(--color-text-faint);letter-spacing:.08em;margin-top:4px;">Leong, Lancet 2015</div>
        </div>
        <div class="stat-cell">
          <div class="dh-heavy" style="font-size:56px;color:var(--color-primary);line-height:1;">2.4×</div>
          <div style="font-family:var(--font-display);font-weight:600;font-size:14px;margin-top:12px;color:var(--color-text);">Sarcopenia detection</div>
          <div class="dh-mono" style="font-size:11px;color:var(--color-text-faint);letter-spacing:.08em;margin-top:4px;">vs. body comp scans</div>
        </div>
        <div class="stat-cell">
          <div class="dh-heavy" style="font-size:56px;color:var(--color-primary);line-height:1;">7 min</div>
          <div style="font-family:var(--font-display);font-weight:600;font-size:14px;margin-top:12px;color:var(--color-text);">Daily protocol</div>
          <div class="dh-mono" style="font-size:11px;color:var(--color-text-faint);letter-spacing:.08em;margin-top:4px;">3 rounds · 30s hang</div>
        </div>
        <div class="stat-cell">
          <div class="dh-heavy" style="font-size:56px;color:var(--color-primary);line-height:1;">84 d</div>
          <div style="font-family:var(--font-display);font-weight:600;font-size:14px;margin-top:12px;color:var(--color-text);">Median plateau-break</div>
          <div class="dh-mono" style="font-size:11px;color:var(--color-text-faint);letter-spacing:.08em;margin-top:4px;">across our cohort</div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE CASE — three pillars -->
  <section id="protocol" style="padding:120px 64px;background:var(--color-bg);">
    <div style="max-width:1200px;margin:0 auto;">
      <div class="dh-eyebrow" style="margin-bottom:16px;">§ II · The Case</div>
      <h2 class="dh-heavy" style="font-size:96px;margin:0 0 80px;max-width:900px;line-height:0.95;">
        One bar.<br/><span style="color:var(--color-text-muted);">Three reasons</span> to hang.
      </h2>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:32px;">
        {[
          { n: "01", title: "Longevity", body: "Grip strength predicts mortality more accurately than systolic blood pressure. The flexor digitorum is a window into systemic muscle quality.", tag: "PRIMARY OUTCOME" },
          { n: "02", title: "Decompression", body: "Passive hanging reverses spinal compression accumulated through sitting. 60 seconds buys you 4mm of disc rehydration.", tag: "STRUCTURAL" },
          { n: "03", title: "Shoulder Health", body: "Active and passive hangs restore scapular mobility and rotator-cuff integrity — the John Kirsch protocol applied at home.", tag: "PROPHYLACTIC" },
        ].map((p, i) => (
          <div class={`scroll-reveal ${i === 1 ? 'scroll-reveal-d1' : i === 2 ? 'scroll-reveal-d2' : ''}`}>
            <div style="position:relative;padding-top:24px;">
              <div class="dh-mono" style={`position:absolute;top:0;left:0;font-size:12px;color:var(--color-primary);letter-spacing:.18em;`}>
                /// {p.n}
              </div>
              <div class="dh-eyebrow" style="margin-bottom:12px;">{p.tag}</div>
              <h3 class="dh-display" style="font-size:34px;font-weight:600;margin:0 0 12px;">{p.title}</h3>
              <p style="font-size:16px;color:var(--color-text-muted);margin:0;line-height:1.6;">{p.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HANG TIMER -->
  <section id="timer" style="padding:100px 64px;background:var(--color-surface);border-top:1px solid var(--color-divider);border-bottom:1px solid var(--color-divider);">
    <div style="max-width:800px;margin:0 auto;">
      <div class="scroll-reveal">
        <div style="text-align:center;margin-bottom:48px;">
          <div class="dh-eyebrow" style="margin-bottom:12px;">· MODULE 01 / HANG TIMER</div>
          <h2 class="dh-display" style="font-size:44px;font-weight:600;margin:0;">
            Start your session.
          </h2>
        </div>
      </div>
      <div class="scroll-reveal scroll-reveal-d3">
        <HangTimer client:visible initialWork={30} initialRest={60} rounds={3} />
      </div>
    </div>
  </section>

  <!-- PROTOCOL CALCULATOR -->
  <section id="studies" style="padding:100px 64px;background:var(--color-bg);">
    <div style="max-width:1200px;margin:0 auto;">
      <div class="scroll-reveal">
        <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:28px;">
          <div>
            <div class="dh-eyebrow" style="margin-bottom:10px;">· MODULE 02 / PROTOCOL ENGINE</div>
            <h2 class="dh-display" style="font-size:44px;font-weight:600;margin:0;line-height:1.1;">
              Tell us your numbers. Get your protocol.
            </h2>
          </div>
          <span class="dh-tag">v 1.4.2 · DH-PROTOCOL</span>
        </div>
      </div>
      <div class="scroll-reveal scroll-reveal-d3">
        <ProtocolCalculator client:visible />
      </div>
    </div>
  </section>

  <!-- CTA / SIGNUP -->
  <section id="signup" style="padding:120px 64px;background:var(--color-primary);color:var(--color-text-inverse);position:relative;overflow:hidden;">
    <div style="max-width:1100px;margin:0 auto;">
      <h2 class="dh-heavy" style="font-size:clamp(64px,9vw,140px);margin:0;line-height:0.92;">
        START<br/>HANGING.
      </h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;margin-top:56px;align-items:end;">
        <p class="dh-display" style="font-size:22px;font-weight:500;margin:0;line-height:1.4;max-width:540px;">
          7 minutes a day. 12 weeks. We'll send you the protocol, a hang timer, and one weekly progress chart. Nothing else.
        </p>
        <SignupForm client:visible dark={true} />
      </div>
    </div>
    <div class="dh-heavy" style="position:absolute;bottom:-80px;right:-40px;font-size:380px;color:rgba(0,0,0,0.06);line-height:0.8;pointer-events:none;letter-spacing:-0.05em;">HANG</div>
  </section>

  <Footer />

  <style>
    .stat-cell {
      background: var(--color-bg);
      padding: 32px 24px;
    }
  </style>

  <script>
    const hero = document.getElementById('hero-content');
    if (hero) {
      window.addEventListener('scroll', () => {
        const p = Math.min(1, window.scrollY / 600);
        hero.style.transform = `scale(${1 + p * 0.15})`;
        hero.style.opacity = String(1 - p * 0.7);
        hero.style.filter = `blur(${p * 6}px)`;
      }, { passive: true });
    }
  </script>
</Base>
