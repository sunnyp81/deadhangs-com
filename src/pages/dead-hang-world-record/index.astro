            <tr><td>Monday</td><td>Max duration</td><td>1 max attempt + 3 sets at 70%</td></tr>
            <tr><td>Tuesday</td><td>Weighted hangs</td><td>5×15 sec with +25% BW</td></tr>
            <tr><td>Wednesday</td><td>Rest</td><td>Active recovery, wrist mobility</td></tr>
            <tr><td>Thursday</td><td>Endurance intervals</td><td>12×30 sec on / 15 sec off</td></tr>
