  description="Contact DeadHangs.com â€” reach our team with questions about dead hang training, content corrections, or advertising enquiries."
  canonical="https://deadhangs.com/contact/"
  schema={`<script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact DeadHangs.com",
    "description": "Get in touch with the DeadHangs.com team.",
    "publisher": {
      "@type": "Organization",
      "name": "DeadHangs.com",
      "url": "https://deadhangs.com",
      "email": "hello@deadhangs.com"
    },
    "mainEntityOfPage": "https://deadhangs.com/contact/"
  }</script>`}
>
  <div class="article-header">
    <div class="article-breadcrumb">
      <a href="/">Home</a><span class="sep">/</span>Contact Us
    </div>
  </div>
  <div class="article-body">
    <Fragment set:html={`<div class="content">
    

    <div class="container">
      <div class="breadcrumb"><a href="/">Home</a><span>â€º</span> Contact</div>
