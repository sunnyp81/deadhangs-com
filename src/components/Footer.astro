---
---
<footer style="background:var(--color-bg);padding:48px 64px 32px;border-top:1px solid var(--color-divider);">
  <div style="max-width:1200px;margin:0 auto;display:flex;align-items:flex-start;justify-content:space-between;gap:40px;">
    <div style="max-width:320px;">
      <div style="display:flex;align-items:center;gap:8px;">
        <svg width="20" height="20" viewBox="0 0 20 20">
          <rect x="2" y="3" width="16" height="2.5" fill="var(--color-primary)"/>
          <rect x="9" y="5" width="2" height="6" fill="var(--color-text)"/>
          <circle cx="10" cy="13" r="3" fill="none" stroke="var(--color-text)" stroke-width="1.6"/>
        </svg>
        <span class="dh-display" style="font-weight:700;font-size:16px;letter-spacing:-0.02em;">
          deadhangs<span style="color:var(--color-primary)">.com</span>
        </span>
      </div>
      <p style="margin-top:16px;font-size:13px;color:var(--color-text-muted);">
        Dead hang training protocols, timers, and the science behind grip strength and longevity.
      </p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:48px;">
      {[
        { heading: "Popular", links: [
          { label: "Dead Hang Times by Age", href: "/dead-hang-time-by-age/" },
          { label: "Dead Hang World Record", href: "/dead-hang-world-record/" },
          { label: "Dead Hang Calculator", href: "/dead-hang-calculator/" },
          { label: "Dead Hang Standards", href: "/dead-hang-standards/" },
        ]},
        { heading: "Guides", links: [
          { label: "Dead Hang Guide", href: "/deadhang-guide/" },
          { label: "How to Dead Hang", href: "/how-to-deadhang/" },
          { label: "Training Programs", href: "/training-programs/" },
          { label: "Grip Strength", href: "/grip-strength/" },
        ]},
        { heading: "Site", links: [
          { label: "About", href: "/about/" },
          { label: "Contact", href: "/contact/" },
          { label: "Privacy", href: "/privacy/" },
        ]},
      ].map((col) => (
        <div>
          <div class="dh-eyebrow" style="margin-bottom:12px;">{col.heading}</div>
          {col.links.map(l => (
            <a href={l.href} style="display:block;font-size:13px;color:var(--color-text-muted);margin-bottom:8px;">{l.label}</a>
          ))}
        </div>
      ))}
    </div>
  </div>
  <hr class="dh-rule" style="margin-top:32px;"/>
  <div style="max-width:1200px;margin:16px auto 0;display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:10px;color:var(--color-text-faint);letter-spacing:.12em;text-transform:uppercase;">
    <span>&copy; 2026 deadhangs.com</span>
    <span>Evidence-based training</span>
  </div>
</footer>
